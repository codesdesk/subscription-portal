{
  "name": "invoice-subscription-shopify-app",
  "private": true,
  "type": "module",
  "main": "app.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "react-router build",
    "dev": "shopify app dev",
    "postinstall": "prisma generate && react-router build",
    "start": "node app.js",
    "typecheck": "react-router typegen && tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "cron:subscriptions": "tsx scripts/run-subscription-cron.ts",
    "lint": "eslint ."
  },
  "dependencies": {
    "@prisma/client": "^6.10.1",
    "@react-router/dev": "^7.6.3",
    "@react-router/node": "^7.6.3",
    "@react-router/serve": "^7.6.3",
    "@shopify/app-bridge-react": "^4.2.2",
    "@shopify/polaris": "^13.9.5",
    "@shopify/shopify-app-react-router": "^1.2.1",
    "@shopify/shopify-app-session-storage-prisma": "^9.0.1",
    "isbot": "^5.1.28",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.6.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.8",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "eslint": "^9.30.0",
    "prisma": "^6.10.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^7.0.0"
  }
}
